# ============== Upstash Redis ==============
# Vercel KV эсвэл Upstash Redis-аас авна.
# Vercel KV ашиглавал автоматаар KV_REST_API_URL/TOKEN орчны хувьсагч үүснэ.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ============== OpenRouter ==============
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Зөвлөмжтэй model — монгол хэлэнд хамгийн сайн
MODEL=google/gemini-2.5-flash

# ============== Optional ==============
# Хэрэв Vercel-ээс гадуур domain ашиглавал тавь
# PUBLIC_URL=https://your-custom-domain.com

# Локал dev port
PORT=4000
