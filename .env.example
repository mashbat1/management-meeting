# ============== Upstash Redis ==============
# Vercel KV эсвэл Upstash Redis-аас авна.
# Vercel KV ашиглавал автоматаар KV_REST_API_URL/TOKEN орчны хувьсагч үүснэ.
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ============== OpenRouter ==============
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model сонголт (OpenRouter дээр байгаа гол варинтууд):
#   openai/gpt-4o-mini    $0.15/$0.60 per M  (~$0.0003/дуудалт)  ⭐ ЗӨВЛӨМЖ
#   openai/gpt-4.1-nano   $0.10/$0.40 per M  (хамгийн хямд GPT-4)
#   openai/gpt-4.1-mini   $0.40/$1.60 per M  (илүү ухаалаг mini)
#   openai/gpt-4.1        $2.00/$8.00 per M  (full size)
#   openai/gpt-4o         $2.50/$10.00 per M (flagship)
#   google/gemini-2.5-flash      $0.30/$2.50 per M
#   anthropic/claude-haiku-4.5   $1/$5 per M
MODEL=openai/gpt-4o-mini

# ============== Optional ==============
# Хэрэв Vercel-ээс гадуур domain ашиглавал тавь
# PUBLIC_URL=https://your-custom-domain.com

# Локал dev port
PORT=4000
